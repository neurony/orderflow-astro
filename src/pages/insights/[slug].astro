---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const [articles, pages, caseStudies] = await Promise.all([
    getCollection('articles'),
    getCollection('pages'),
    getCollection('caseStudies'),
  ]);

  return [
    ...articles.map((entry) => ({
      params: { slug: entry.id },
      props: { entry, contentType: 'article' as const },
    })),
    ...pages.map((entry) => ({
      params: { slug: entry.id },
      props: { entry, contentType: 'page' as const },
    })),
    ...caseStudies.map((entry) => ({
      params: { slug: entry.id },
      props: { entry, contentType: 'caseStudy' as const },
    })),
  ];
}

const { entry, contentType } = Astro.props;
const { Content } = await render(entry);

// --- SEO fields (unified across content types) ---
const pageTitle = entry.data.seoTitle || `${entry.data.title} | Orderflow`;
const pageDescription = entry.data.seoDescription || (entry.data as any).description || '';
const canonicalUrl = entry.data.canonicalUrl || undefined;

// Image: articles use `image`, pages/caseStudies use `ogImage`
const heroImage = contentType === 'article'
  ? (entry.data as any).image
  : (entry.data as any).ogImage;

// OG type
const ogType = contentType === 'page'
  ? ((entry.data as any).ogType || 'website')
  : 'article';

// Noindex (pages only)
const noindex = contentType === 'page' ? ((entry.data as any).noindex || false) : false;

// Date fields
const publishDate = contentType === 'article'
  ? (entry.data as any).date
  : (entry.data as any).pubDate;
const updatedDate = (entry.data as any).updatedDate;

// Article OG metadata
const articleMeta = contentType !== 'page' ? {
  publishedTime: publishDate || '',
  modifiedTime: updatedDate,
  author: contentType === 'article'
    ? (entry.data as any).author?.name
    : ((entry.data as any).author || 'OrderFlow Team'),
  section: contentType === 'article' ? (entry.data as any).category : undefined,
} : undefined;

// --- JSON-LD schemas ---
const jsonLdSchemas: Record<string, any>[] = [];

// Breadcrumb schema (all types: Home > Insights > title)
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orderflow.biz' },
    { '@type': 'ListItem', position: 2, name: 'Insights', item: 'https://orderflow.biz/insights' },
    { '@type': 'ListItem', position: 3, name: entry.data.title },
  ],
};
jsonLdSchemas.push(breadcrumbSchema);

// Content-type-specific schemas
if (contentType === 'article') {
  const articleSchema = {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: entry.data.title,
    description: pageDescription,
    image: heroImage ? `https://orderflow.biz${heroImage}` : undefined,
    datePublished: publishDate,
    dateModified: updatedDate || publishDate,
    author: (entry.data as any).author ? {
      '@type': 'Person',
      name: (entry.data as any).author.name,
      jobTitle: (entry.data as any).author.role,
    } : undefined,
    publisher: { '@id': 'https://orderflow.biz/#organization' },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': `https://orderflow.biz/insights/${entry.id}`,
    },
  };
  jsonLdSchemas.push(articleSchema);
} else if (contentType === 'page') {
  if ((entry.data as any).schemaType === 'SoftwareApplication') {
    const softwareSchema = {
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: entry.data.title,
      description: pageDescription,
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'EUR',
        availability: 'https://schema.org/OnlineOnly',
      },
      publisher: { '@id': 'https://orderflow.biz/#organization' },
    };
    jsonLdSchemas.push(softwareSchema);
  }
} else if (contentType === 'caseStudy') {
  const caseStudySchema = {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: entry.data.title,
    description: pageDescription,
    image: heroImage ? `https://orderflow.biz${heroImage}` : undefined,
    datePublished: publishDate,
    dateModified: updatedDate || publishDate,
    author: {
      '@type': 'Organization',
      name: (entry.data as any).author || 'OrderFlow Team',
    },
    publisher: { '@id': 'https://orderflow.biz/#organization' },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': `https://orderflow.biz/insights/${entry.id}`,
    },
  };
  jsonLdSchemas.push(caseStudySchema);
}

// FAQ schema (all content types)
const faqItems = (entry.data as any).faq || [];
if (faqItems.length > 0) {
  const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item: any) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  };
  jsonLdSchemas.push(faqSchema);
}

// Related articles (for article content type)
const allArticles = contentType === 'article' ? await getCollection('articles') : [];
const relatedArticles = allArticles
  .filter((a) => a.id !== entry.id && a.data.category === (entry.data as any).category)
  .slice(0, 3);

// Case study specific data
const stats = contentType === 'caseStudy' ? ((entry.data as any).stats || []) : [];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonicalUrl}
  ogImage={heroImage}
  ogType={ogType}
  noindex={noindex}
  article={articleMeta}
  jsonLd={jsonLdSchemas}
>
  <main>
    {/* ===== ARTICLE HERO ===== */}
    <section class="section section--article-hero">
      <div class="section__card section__card--muted article-hero">
        <div class="article-hero__content">
          <a href="/insights" class="article-hero__back" aria-label="Back to Insights">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M15 6L9 12L15 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <h1 class="article-hero__title" data-reveal="up">{entry.data.title}</h1>

          {/* Article meta: category tag, date, read time */}
          {contentType === 'article' && (
            <div class="article-hero__meta" data-reveal="up" style="--delay:0.1s">
              {(entry.data as any).category && <span class="article-hero__tag">{(entry.data as any).category}</span>}
              <div class="article-hero__meta-row">
                <span class="article-hero__meta-item">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M19 4H5C3.89543 4 3 4.89543 3 6V20C3 21.1046 3.89543 22 5 22H19C20.1046 22 21 21.1046 21 20V6C21 4.89543 20.1046 4 19 4Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M16 2V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M8 2V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M3 10H21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {(entry.data as any).date}
                </span>
                {(entry.data as any).readTime && (
                  <span class="article-hero__meta-item">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M12 7V12L15 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    {(entry.data as any).readTime}
                  </span>
                )}
              </div>
            </div>
          )}

          {/* Page (product) meta: subtitle */}
          {contentType === 'page' && (entry.data as any).seoDescription && (
            <p class="article-hero__subtitle" data-reveal="up" style="--delay:0.1s">
              {(entry.data as any).seoDescription}
            </p>
          )}

          {/* Case study meta: industry tag, company, client */}
          {contentType === 'caseStudy' && ((entry.data as any).clientName || (entry.data as any).clientCompany) && (
            <div class="article-hero__meta" data-reveal="up" style="--delay:0.1s">
              {(entry.data as any).industry && <span class="article-hero__tag">{(entry.data as any).industry}</span>}
              <div class="article-hero__meta-row">
                {(entry.data as any).clientCompany && (
                  <span class="article-hero__meta-item">
                    <strong>{(entry.data as any).clientCompany}</strong>
                  </span>
                )}
                {(entry.data as any).clientName && (
                  <span class="article-hero__meta-item">
                    {(entry.data as any).clientName}{(entry.data as any).clientRole ? `, ${(entry.data as any).clientRole}` : ''}
                  </span>
                )}
              </div>
            </div>
          )}
        </div>
        {heroImage && (
          <div class="article-hero__image-wrap">
            <img src={heroImage} alt={entry.data.title} class="article-hero__image">
          </div>
        )}
      </div>
    </section>

    {/* ===== CASE STUDY STATS ===== */}
    {contentType === 'caseStudy' && stats.length > 0 && (
      <section class="section">
        <div class="section__card section__card--white">
          <div class="stats-grid" data-reveal-stagger>
            {stats.map((stat: any) => (
              <div class="stats-grid__item" data-reveal="up">
                <span class="stats-grid__value">{stat.value}</span>
                <span class="stats-grid__label">{stat.label}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* ===== BODY ===== */}
    <section class="section section--article-body">
      <div class="article-body-wrapper">
        <article class="article-prose">
          <Content />

        </article>
      </div>
    </section>

    {/* ===== FAQ SECTION (all content types) ===== */}
    {faqItems.length > 0 && (
      <section class="section section--faq">
        <div class="section__card section__card--white">
          <h2 class="section__title" data-reveal="up">Frequently Asked Questions</h2>
          <div class="faq-list" data-reveal-stagger>
            {faqItems.map((item: any) => (
              <details class="faq-item" data-reveal="up">
                <summary class="faq-item__question">{item.question}</summary>
                <div class="faq-item__answer">
                  <p>{item.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* ===== RELATED ARTICLES (articles only) ===== */}
    {contentType === 'article' && relatedArticles.length > 0 && (
      <section class="section section--related-articles">
        <div class="section__card section__card--white related-articles">
          <h2 class="related-articles__title" data-reveal="up">Other relevant articles for you</h2>
          <div class="related-articles__grid" data-reveal-stagger>
            {relatedArticles.map((related) => (
              <a href={`/insights/${related.id}`} class="article-card" data-reveal="up">
                <div class="article-card__image-wrap">
                  {related.data.image && <img src={related.data.image} alt="" class="article-card__image" loading="lazy">}
                  {related.data.category && <span class="article-card__tag">{related.data.category}</span>}
                </div>
                <span class="article-card__date">{related.data.date}</span>
                <h3 class="article-card__title">{related.data.title}</h3>
                <span class="article-card__read-link">Read article</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>
</BaseLayout>
