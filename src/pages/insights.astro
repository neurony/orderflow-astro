---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Fetch all three collections
const [articles, pages, caseStudies] = await Promise.all([
  getCollection('articles'),
  getCollection('pages'),
  getCollection('caseStudies'),
]);

// Format date as dd-mm-yyyy
function formatDate(dateStr: string): string {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  const day = String(d.getDate()).padStart(2, '0');
  const month = String(d.getMonth() + 1).padStart(2, '0');
  const year = d.getFullYear();
  return `${day}-${month}-${year}`;
}

// Normalize into a unified list
type InsightItem = {
  id: string;
  url: string;
  title: string;
  date: string;
  dateFormatted: string;
  image?: string;
  category?: string;
  contentTypeLabel: string;
  filterTag: string;
};

const allItems: InsightItem[] = [
  ...articles.map((a) => ({
    id: a.id,
    url: a.data.funnel === 'BOFU' ? `/${a.id}` : `/insights/${a.id}`,
    title: a.data.title,
    date: a.data.date || '',
    dateFormatted: formatDate(a.data.date || ''),
    image: a.data.image,
    category: a.data.category,
    contentTypeLabel: 'Article',
    filterTag: a.data.category || 'Article',
  })),
  ...pages.map((p) => ({
    id: p.id,
    url: `/${p.id}`,
    title: p.data.title,
    date: (p.data as any).pubDate || '',
    dateFormatted: formatDate((p.data as any).pubDate || ''),
    image: (p.data as any).ogImage,
    category: undefined,
    contentTypeLabel: 'Product Guide',
    filterTag: 'Product Guide',
  })),
  ...caseStudies.map((c) => ({
    id: c.id,
    url: `/${c.id}`,
    title: c.data.title,
    date: (c.data as any).pubDate || '',
    dateFormatted: formatDate((c.data as any).pubDate || ''),
    image: (c.data as any).ogImage,
    category: undefined,
    contentTypeLabel: 'Case Study',
    filterTag: 'Case Study',
  })),
];

// Sort by date descending
const sortedItems = allItems.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orderflow.biz' },
    { '@type': 'ListItem', position: 2, name: 'Insights' },
  ],
};

// Build unique filter tags (content types + article categories, deduplicated)
const allTags = [...new Set(allItems.map((item) => item.filterTag))];
---

<BaseLayout
  title="Insights | Order Processing Automation | Orderflow"
  description="Explore articles and insights on AI-powered order processing, distribution automation, and ERP integration for modern businesses."
  jsonLd={breadcrumbSchema}
>
  <main>
    <!-- Hero section -->
    <section class="section section--insights-hero">
      <div class="section__card section__card--muted insights-hero">
        <div class="insights-hero__text">
          <h1 class="insights-hero__title" data-reveal="up">Insights</h1>
          <p class="insights-hero__subtitle" data-reveal="up" style="--delay:0.1s">Explore our latest insights on order automation, industry updates, and scaling distribution operations.</p>
        </div>
        <div class="insights-hero__tags" data-reveal="up" style="--delay:0.2s">
          <button class="tag tag--active" data-filter="all">All</button>
          {allTags.map((tag) => (
            <button class="tag" data-filter={tag}>{tag}</button>
          ))}
        </div>
      </div>
    </section>

    <!-- Articles section -->
    <section class="section section--articles">
      <div class="section__card section__card--white articles">
        <!-- Header row -->
        <div class="articles__header" data-reveal="up">
          <h2 class="articles__title" id="articles-count">{sortedItems.length} articles for you</h2>
        </div>

        <!-- Article grid -->
        <div class="article-grid" id="article-grid" data-reveal-stagger>
          {sortedItems.map((item, index) => (
            <a href={item.url} class="article-card" data-reveal="up" data-tag={item.filterTag}>
              <div class="article-card__image-wrap">
                {item.image && <img src={item.image} alt={item.title} class="article-card__image" width="816" height="640" loading={index === 0 ? 'eager' : 'lazy'} fetchpriority={index === 0 ? 'high' : undefined}>}
                {(item.category || item.contentTypeLabel) && (
                  <span class="article-card__tag">{item.category || item.contentTypeLabel}</span>
                )}
              </div>
              <span class="article-card__date">{item.dateFormatted}</span>
              <h3 class="article-card__title">{item.title}</h3>
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>

  <script is:inline>
    // Tag filter functionality
    (function() {
      var tags = document.querySelectorAll('[data-filter]');
      var cards = document.querySelectorAll('[data-tag]');
      var countEl = document.getElementById('articles-count');

      tags.forEach(function(tag) {
        tag.addEventListener('click', function() {
          // Update active state
          tags.forEach(function(t) { t.classList.remove('tag--active'); });
          tag.classList.add('tag--active');

          var filter = tag.getAttribute('data-filter');
          var visible = 0;

          cards.forEach(function(card) {
            if (filter === 'all' || card.getAttribute('data-tag') === filter) {
              card.style.display = '';
              visible++;
            } else {
              card.style.display = 'none';
            }
          });

          // Update count
          if (countEl) {
            countEl.textContent = visible + (visible === 1 ? ' article for you' : ' articles for you');
          }
        });
      });
    })();
  </script>

<style is:global>
/* ----- Active nav link ----- */
.nav-link--active {
  background-color: var(--color-black-5);
}

/* ----- Insights Hero ----- */
.insights-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-32);
  padding: var(--space-64) var(--space-72);
}

.insights-hero__text {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-16);
  max-width: 646px;
  text-align: center;
}

.insights-hero__title {
  font-size: var(--text-5xl);
  font-weight: var(--weight-regular);
  line-height: var(--leading-tight);
  color: var(--color-neutral-900);
}

.insights-hero__subtitle {
  font-size: var(--text-lg);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--color-neutral-900);
}

/* ----- Filter Tags ----- */
.insights-hero__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-12);
  justify-content: center;
  max-width: 870px;
}

.tag {
  background-color: var(--color-white);
  border: 1px solid var(--color-neutral-200);
  border-radius: var(--radius-md);
  padding: var(--space-4) var(--space-12);
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--weight-regular);
  line-height: var(--leading-normal);
  color: var(--color-neutral-900);
  white-space: nowrap;
  cursor: pointer;
  box-shadow: var(--shadow-sm);
  transition: background-color 0.15s ease, border-color 0.15s ease;
}

.tag:hover {
  background-color: var(--color-neutral-50);
}

.tag--active {
  background-color: var(--color-neutral-900);
  border-color: var(--color-neutral-900);
  color: #fff;
}

.tag--active:hover {
  background-color: var(--color-neutral-700);
}

/* ----- Articles Section ----- */
.articles {
  display: flex;
  flex-direction: column;
  gap: var(--space-32);
  padding: 0 var(--space-72) var(--space-64);
}

.articles__header {
  display: flex;
  align-items: center;
  width: 100%;
}

.articles__title {
  font-size: var(--text-4xl);
  font-weight: var(--weight-regular);
  line-height: var(--leading-snug);
  color: var(--color-neutral-900);
}

/* ----- Article Grid ----- */
.article-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-48);
}

/* ----- Article Card ----- */
.article-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
  text-decoration: none;
  color: inherit;
}

.article-card__image-wrap {
  position: relative;
  aspect-ratio: 408 / 320;
  border-radius: var(--radius-xl);
  overflow: hidden;
  background-color: var(--color-neutral-100, #f3f4f6);
}

.article-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.article-card:hover .article-card__image {
  transform: scale(1.03);
}

.article-card__tag {
  position: absolute;
  top: 14px;
  left: 13px;
  background-color: var(--color-white);
  border: 1px solid var(--color-neutral-200);
  border-radius: var(--radius-md);
  padding: var(--space-4) var(--space-12);
  font-size: var(--text-sm);
  font-weight: var(--weight-regular);
  line-height: var(--leading-normal);
  color: var(--color-neutral-900);
  box-shadow: var(--shadow-sm);
}

.article-card__date {
  font-size: var(--text-lg);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--color-neutral-500);
}

.article-card__title {
  font-size: var(--text-2xl);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--color-neutral-900);
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ----- Large-screen breakpoint (2K+) ----- */
@media (min-width: 2550px) {
  .article-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

/* ----- Responsive ----- */
@media (max-width: 1024px) {
  .article-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-32);
  }

  .articles {
    padding-left: var(--space-32);
    padding-right: var(--space-32);
  }

  .insights-hero {
    padding-left: var(--space-32);
    padding-right: var(--space-32);
  }
}

@media (max-width: 640px) {
  .article-grid {
    grid-template-columns: 1fr;
    gap: var(--space-32);
  }

  .insights-hero__title {
    font-size: var(--text-4xl);
  }

  .articles__title {
    font-size: var(--text-3xl);
  }

  .articles__header {
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-16);
  }

  .articles {
    padding-left: var(--space-24);
    padding-right: var(--space-24);
  }

  .insights-hero {
    padding-left: var(--space-24);
    padding-right: var(--space-24);
  }
}
</style>
</BaseLayout>
