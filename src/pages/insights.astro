---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const sortedArticles = articles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orderflow.com' },
    { '@type': 'ListItem', position: 2, name: 'Insights' },
  ],
};

// Extract unique categories from articles
const categories = [...new Set(sortedArticles.map((a) => a.data.category).filter(Boolean))];
---

<BaseLayout
  title="Insights — Articles on Order Processing Automation | Orderflow"
  description="Explore articles and insights on AI-powered order processing, distribution automation, and ERP integration for modern businesses."
  canonical="https://orderflow.com/insights"
  jsonLd={breadcrumbSchema}
>
  <!-- HEADER / NAV -->
  <header class="site-header">
    <nav class="site-header__inner" aria-label="Main navigation">
      <a href="/" class="nav-logo" aria-label="Orderflow home">
        <svg class="nav-logo__mark" width="138" height="24" viewBox="0 0 138 24" fill="none" aria-hidden="true">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M4.5194 14.6866H1.07321L1.07297 14.7568C1.07297 16.5531 1.43867 18.1511 2.16959 19.5505C2.92143 20.95 3.96547 22.0469 5.30219 22.8407C6.63891 23.6135 8.21585 24 10.0329 24C11.8499 24 13.4268 23.6134 14.7636 22.8407C16.1003 22.0469 17.1341 20.95 17.8651 19.5505C18.6169 18.1511 18.9933 16.5531 18.9933 14.7568C18.9933 12.9397 18.6169 11.3315 17.8651 9.93207C17.1341 8.53262 16.1003 7.43615 14.7636 6.64242C13.4878 5.88487 11.9932 5.48855 10.2798 5.454V8.52631C11.3229 8.56136 12.2225 8.82093 12.9781 9.30531C13.7925 9.80661 14.4191 10.5273 14.8577 11.4672C15.2963 12.4071 15.5155 13.5037 15.5155 14.7568C15.5155 15.9891 15.2963 17.0755 14.8577 18.0154C14.4191 18.9344 13.7925 19.6551 12.9781 20.1773C12.1635 20.6786 11.1816 20.9293 10.0329 20.9293C8.88427 20.9293 7.89198 20.6786 7.0566 20.1773C6.24214 19.6551 5.61555 18.9344 5.17694 18.0154C4.73834 17.0755 4.51916 15.9891 4.51916 14.7568L4.5194 14.6866Z" fill="#1E2939"/>
          <path fill-rule="evenodd" clip-rule="evenodd" d="M47.4988 23.4985H44.1468V20.8351C43.6247 21.7959 42.904 22.569 41.9851 23.1538C41.0661 23.7178 39.9067 24 38.5074 24C36.8993 24 35.5001 23.6134 34.3097 22.8407C33.1401 22.0469 32.2314 20.95 31.5839 19.5505C30.9365 18.1511 30.6125 16.5531 30.6125 14.7568C30.6125 12.9397 30.9365 11.3315 31.5839 9.93207C32.2314 8.53261 33.1401 7.43615 34.3097 6.64242C35.5001 5.84875 36.8992 5.45155 38.5074 5.45152C39.8441 5.45152 40.9826 5.73376 41.9225 6.29772C42.8623 6.86168 43.6038 7.64493 44.1468 8.64748V0H47.4988V23.4985ZM38.9462 8.52222C37.9437 8.52222 37.0767 8.78312 36.3457 9.30531C35.6147 9.80661 35.0507 10.5273 34.6539 11.4672C34.2571 12.4071 34.0587 13.5037 34.0587 14.7568C34.0587 15.9891 34.2571 17.0755 34.6539 18.0154C35.0507 18.9344 35.6147 19.6551 36.3457 20.1773C37.0767 20.6786 37.9437 20.9293 38.9462 20.9293C40.1157 20.9293 41.0764 20.6683 41.8283 20.1462C42.6011 19.6032 43.1757 18.8616 43.5516 17.9217C43.9485 16.9818 44.1468 15.9265 44.1468 14.7568C44.1468 13.5664 43.9484 12.5012 43.5516 11.5614C43.1757 10.6214 42.6011 9.87994 41.8283 9.33687C41.0764 8.7938 40.1158 8.52223 38.9462 8.52222Z" fill="#1E2939"/>
          <path d="M8.81124 13.2179L1.08648 13.2179L1.08648 10.8409L4.75372 10.8409L1.24675e-06 6.08677L1.68069 4.40598L6.43439 9.16003L6.43439 5.49258L8.81124 5.49258L8.81124 13.2179Z" fill="#FFD230"/>
        </svg>
      </a>

      <button class="mobile-menu-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Toggle menu">
        <svg class="mobile-menu-toggle__icon--open" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        <svg class="mobile-menu-toggle__icon--close" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M6 18L18 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>

      <ul id="nav-menu" class="nav-links" role="list">
        <li><a href="/" class="nav-link">About us</a></li>
        <li><a href="/contact" class="nav-link">Contact</a></li>
        <li><a href="/insights" class="nav-link nav-link--active">Insights</a></li>
      </ul>

      <a href="/book-a-call" class="btn btn--dark-stroke" aria-label="Book a call">Book a call</a>
    </nav>
  </header>

  <main>
    <!-- Hero section -->
    <section class="section section--insights-hero">
      <div class="section__card section__card--muted insights-hero">
        <div class="insights-hero__text">
          <h1 class="insights-hero__title" data-reveal="up">Insights</h1>
          <p class="insights-hero__subtitle" data-reveal="up" style="--delay:0.1s">Delve deeper into our latest insights on order automation, industry updates, and scaling distribution operations.</p>
        </div>
        <div class="insights-hero__tags" data-reveal="up" style="--delay:0.2s">
          {categories.map((cat) => (
            <button class="tag">{cat}</button>
          ))}
        </div>
      </div>
    </section>

    <!-- Articles section -->
    <section class="section section--articles">
      <div class="section__card section__card--white articles">
        <!-- Header row -->
        <div class="articles__header" data-reveal="up">
          <h2 class="articles__title">{sortedArticles.length} articles for you</h2>
          <div class="articles__sort">
            <span class="articles__sort-label">Sort by:</span>
            <span class="articles__sort-value">Newest</span>
            <svg class="articles__sort-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>

        <!-- Article grid -->
        <div class="article-grid" data-reveal-stagger>
          {sortedArticles.map((article) => (
            <a href={`/articles/${article.slug}`} class="article-card" data-reveal="up">
              <div class="article-card__image-wrap">
                {article.data.image && <img src={article.data.image} alt="" class="article-card__image" loading="lazy">}
                {article.data.category && <span class="article-card__tag">{article.data.category}</span>}
              </div>
              <span class="article-card__date">{article.data.date}</span>
              <h3 class="article-card__title">{article.data.title}</h3>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__top" data-reveal="up">
          <a href="/" class="nav-logo nav-logo--footer" aria-label="Orderflow home">
            <svg class="nav-logo__mark" width="184" height="32" viewBox="0 0 138 24" fill="none" aria-hidden="true">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M4.5194 14.6866H1.07321L1.07297 14.7568C1.07297 16.5531 1.43867 18.1511 2.16959 19.5505C2.92143 20.95 3.96547 22.0469 5.30219 22.8407C6.63891 23.6135 8.21585 24 10.0329 24C11.8499 24 13.4268 23.6134 14.7636 22.8407C16.1003 22.0469 17.1341 20.95 17.8651 19.5505C18.6169 18.1511 18.9933 16.5531 18.9933 14.7568C18.9933 12.9397 18.6169 11.3315 17.8651 9.93207C17.1341 8.53262 16.1003 7.43615 14.7636 6.64242C13.4878 5.88487 11.9932 5.48855 10.2798 5.454V8.52631C11.3229 8.56136 12.2225 8.82093 12.9781 9.30531C13.7925 9.80661 14.4191 10.5273 14.8577 11.4672C15.2963 12.4071 15.5155 13.5037 15.5155 14.7568C15.5155 15.9891 15.2963 17.0755 14.8577 18.0154C14.4191 18.9344 13.7925 19.6551 12.9781 20.1773C12.1635 20.6786 11.1816 20.9293 10.0329 20.9293C8.88427 20.9293 7.89198 20.6786 7.0566 20.1773C6.24214 19.6551 5.61555 18.9344 5.17694 18.0154C4.73834 17.0755 4.51916 15.9891 4.51916 14.7568L4.5194 14.6866Z" fill="#1E2939"/>
              <path fill-rule="evenodd" clip-rule="evenodd" d="M47.4988 23.4985H44.1468V20.8351C43.6247 21.7959 42.904 22.569 41.9851 23.1538C41.0661 23.7178 39.9067 24 38.5074 24C36.8993 24 35.5001 23.6134 34.3097 22.8407C33.1401 22.0469 32.2314 20.95 31.5839 19.5505C30.9365 18.1511 30.6125 16.5531 30.6125 14.7568C30.6125 12.9397 30.9365 11.3315 31.5839 9.93207C32.2314 8.53261 33.1401 7.43615 34.3097 6.64242C35.5001 5.84875 36.8992 5.45155 38.5074 5.45152C39.8441 5.45152 40.9826 5.73376 41.9225 6.29772C42.8623 6.86168 43.6038 7.64493 44.1468 8.64748V0H47.4988V23.4985ZM38.9462 8.52222C37.9437 8.52222 37.0767 8.78312 36.3457 9.30531C35.6147 9.80661 35.0507 10.5273 34.6539 11.4672C34.2571 12.4071 34.0587 13.5037 34.0587 14.7568C34.0587 15.9891 34.2571 17.0755 34.6539 18.0154C35.0507 18.9344 35.6147 19.6551 36.3457 20.1773C37.0767 20.6786 37.9437 20.9293 38.9462 20.9293C40.1157 20.9293 41.0764 20.6683 41.8283 20.1462C42.6011 19.6032 43.1757 18.8616 43.5516 17.9217C43.9485 16.9818 44.1468 15.9265 44.1468 14.7568C44.1468 13.5664 43.9484 12.5012 43.5516 11.5614C43.1757 10.6214 42.6011 9.87994 41.8283 9.33687C41.0764 8.7938 40.1158 8.52223 38.9462 8.52222Z" fill="#1E2939"/>
              <path d="M8.81124 13.2179L1.08648 13.2179L1.08648 10.8409L4.75372 10.8409L1.24675e-06 6.08677L1.68069 4.40598L6.43439 9.16003L6.43439 5.49258L8.81124 5.49258L8.81124 13.2179Z" fill="#FFD230"/>
            </svg>
          </a>
          <div class="footer-social">
            <a href="#" class="footer-social__link" aria-label="LinkedIn"><img src="/insights/icon-linkedin.svg" alt="" class="footer-social__icon"></a>
            <a href="#" class="footer-social__link" aria-label="Instagram"><img src="/insights/icon-instagram.svg" alt="" class="footer-social__icon"></a>
            <a href="#" class="footer-social__link" aria-label="Facebook"><img src="/insights/icon-facebook.svg" alt="" class="footer-social__icon"></a>
            <a href="#" class="footer-social__link" aria-label="Twitter"><img src="/insights/icon-twitter.svg" alt="" class="footer-social__icon"></a>
          </div>
          <ul class="footer-links" role="list">
            <li><a href="/contact" class="nav-link">Contact us</a></li>
            <li><a href="/" class="nav-link">About us</a></li>
            <li><a href="/insights" class="nav-link">Insights</a></li>
            <li><a href="/terms" class="nav-link">Terms &amp; Conditions</a></li>
            <li><a href="/privacy" class="nav-link">Privacy Policy</a></li>
          </ul>
        </div>
        <p class="site-footer__copy">&copy; 2026 Orderflow | Powered by Neurony</p>
      </div>
    </footer>
  </main>

  <script>
    document.querySelector('.mobile-menu-toggle').addEventListener('click', function() {
      const expanded = this.getAttribute('aria-expanded') === 'true';
      this.setAttribute('aria-expanded', !expanded);
      document.getElementById('nav-menu').classList.toggle('nav-links--open', !expanded);
    });
  </script>

  <script>
    (function() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.querySelectorAll('[data-reveal]').forEach(function(el) { el.classList.add('revealed'); });
        return;
      }
      document.querySelectorAll('[data-reveal-stagger]').forEach(function(container) {
        var children = container.querySelectorAll(':scope > [data-reveal]');
        children.forEach(function(child, i) {
          if (!child.style.getPropertyValue('--delay')) { child.style.setProperty('--delay', (i * 0.1) + 's'); }
        });
      });
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) { entry.target.classList.add('revealed'); observer.unobserve(entry.target); }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
      document.querySelectorAll('[data-reveal]').forEach(function(el) { observer.observe(el); });
    })();
  </script>
<style is:global>
/* ----- Active nav link ----- */
.nav-link--active {
  background-color: var(--color-black-5);
}

/* ----- Insights Hero ----- */
.insights-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-32);
  padding: var(--space-64) var(--space-72);
}

.insights-hero__text {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-16);
  max-width: 646px;
  text-align: center;
}

.insights-hero__title {
  font-size: var(--text-5xl);
  font-weight: var(--weight-regular);
  line-height: var(--leading-tight);
  color: var(--color-neutral-900);
}

.insights-hero__subtitle {
  font-size: var(--text-lg);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--color-neutral-900);
}

/* ----- Filter Tags ----- */
.insights-hero__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-12);
  justify-content: center;
  max-width: 870px;
}

.tag {
  background-color: var(--color-white);
  border: 1px solid var(--color-neutral-200);
  border-radius: var(--radius-md);
  padding: var(--space-4) var(--space-12);
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--weight-regular);
  line-height: var(--leading-normal);
  color: var(--color-neutral-900);
  white-space: nowrap;
  cursor: pointer;
  box-shadow: var(--shadow-sm);
  transition: background-color 0.15s ease;
}

.tag:hover {
  background-color: var(--color-neutral-50);
}

.tag--active {
  background-color: var(--color-orange-300);
}

.tag--active:hover {
  background-color: #ffa94d;
}

/* ----- Articles Section ----- */
.articles {
  display: flex;
  flex-direction: column;
  gap: var(--space-32);
  padding: 0 var(--space-72) var(--space-64);
}

.articles__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.articles__title {
  font-size: var(--text-4xl);
  font-weight: var(--weight-regular);
  line-height: var(--leading-snug);
  color: var(--color-neutral-900);
}

.articles__sort {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  background-color: var(--color-white);
  border: 1px solid var(--color-neutral-300);
  border-radius: var(--radius-md);
  padding: var(--space-12) var(--space-12) var(--space-12) var(--space-16);
  font-size: var(--text-base);
  line-height: 0;
  cursor: pointer;
}

.articles__sort-label {
  color: var(--color-neutral-500);
  line-height: var(--leading-normal);
}

.articles__sort-value {
  color: var(--color-neutral-900);
  line-height: var(--leading-normal);
}

.articles__sort-icon {
  width: 20px;
  height: 20px;
  color: var(--color-neutral-900);
  transform: rotate(90deg);
}

/* ----- Article Grid ----- */
.article-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-48);
}

/* ----- Article Card ----- */
.article-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
  text-decoration: none;
  color: inherit;
}

.article-card__image-wrap {
  position: relative;
  aspect-ratio: 408 / 320;
  border-radius: var(--radius-xl);
  overflow: hidden;
}

.article-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.article-card:hover .article-card__image {
  transform: scale(1.03);
}

.article-card__tag {
  position: absolute;
  top: 14px;
  left: 13px;
  background-color: var(--color-white);
  border: 1px solid var(--color-neutral-200);
  border-radius: var(--radius-md);
  padding: var(--space-4) var(--space-12);
  font-size: var(--text-sm);
  font-weight: var(--weight-regular);
  line-height: var(--leading-normal);
  color: var(--color-neutral-900);
  box-shadow: var(--shadow-sm);
}

.article-card__date {
  font-size: var(--text-lg);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--color-neutral-500);
}

.article-card__title {
  font-size: var(--text-2xl);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--color-neutral-900);
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ----- Responsive ----- */
@media (max-width: 1024px) {
  .article-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-32);
  }

  .articles {
    padding-left: var(--space-32);
    padding-right: var(--space-32);
  }

  .insights-hero {
    padding-left: var(--space-32);
    padding-right: var(--space-32);
  }
}

@media (max-width: 640px) {
  .article-grid {
    grid-template-columns: 1fr;
    gap: var(--space-32);
  }

  .insights-hero__title {
    font-size: var(--text-4xl);
  }

  .articles__title {
    font-size: var(--text-3xl);
  }

  .articles__header {
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-16);
  }

  .articles {
    padding-left: var(--space-24);
    padding-right: var(--space-24);
  }

  .insights-hero {
    padding-left: var(--space-24);
    padding-right: var(--space-24);
  }
}
</style>
</BaseLayout>
