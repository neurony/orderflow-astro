---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Fetch all three collections
const [articles, pages, caseStudies] = await Promise.all([
  getCollection('articles'),
  getCollection('pages'),
  getCollection('caseStudies'),
]);

// Normalize into a unified list with a date and contentType label
type InsightItem = {
  id: string;
  title: string;
  date: string;
  image?: string;
  category?: string;
  contentTypeLabel: string;
};

const allItems: InsightItem[] = [
  ...articles.map((a) => ({
    id: a.id,
    title: a.data.title,
    date: a.data.date || '',
    image: a.data.image,
    category: a.data.category,
    contentTypeLabel: 'Article',
  })),
  ...pages.map((p) => ({
    id: p.id,
    title: p.data.title,
    date: (p.data as any).pubDate || '',
    image: (p.data as any).ogImage,
    category: undefined,
    contentTypeLabel: 'Product Guide',
  })),
  ...caseStudies.map((c) => ({
    id: c.id,
    title: c.data.title,
    date: (c.data as any).pubDate || '',
    image: (c.data as any).ogImage,
    category: undefined,
    contentTypeLabel: 'Case Study',
  })),
];

// Sort by date descending
const sortedItems = allItems.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orderflow.biz' },
    { '@type': 'ListItem', position: 2, name: 'Insights' },
  ],
};

// Extract unique categories from articles + content type labels
const articleCategories = [...new Set(articles.map((a) => a.data.category).filter(Boolean))];
const contentTypeLabels = ['Article', 'Product Guide', 'Case Study'];
const categories = [...contentTypeLabels, ...articleCategories];
---

<BaseLayout
  title="Insights — Articles on Order Processing Automation | Orderflow"
  description="Explore articles and insights on AI-powered order processing, distribution automation, and ERP integration for modern businesses."
  canonical="https://orderflow.biz/insights"
  jsonLd={breadcrumbSchema}
>
  <main>
    <!-- Hero section -->
    <section class="section section--insights-hero">
      <div class="section__card section__card--muted insights-hero">
        <div class="insights-hero__text">
          <h1 class="insights-hero__title" data-reveal="up">Insights</h1>
          <p class="insights-hero__subtitle" data-reveal="up" style="--delay:0.1s">Delve deeper into our latest insights on order automation, industry updates, and scaling distribution operations.</p>
        </div>
        <div class="insights-hero__tags" data-reveal="up" style="--delay:0.2s">
          {categories.map((cat) => (
            <button class="tag">{cat}</button>
          ))}
        </div>
      </div>
    </section>

    <!-- Articles section -->
    <section class="section section--articles">
      <div class="section__card section__card--white articles">
        <!-- Header row -->
        <div class="articles__header" data-reveal="up">
          <h2 class="articles__title">{sortedItems.length} articles for you</h2>
          <div class="articles__sort">
            <span class="articles__sort-label">Sort by:</span>
            <span class="articles__sort-value">Newest</span>
            <svg class="articles__sort-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>

        <!-- Article grid -->
        <div class="article-grid" data-reveal-stagger>
          {sortedItems.map((item) => (
            <a href={`/insights/${item.id}`} class="article-card" data-reveal="up">
              <div class="article-card__image-wrap">
                {item.image && <img src={item.image} alt="" class="article-card__image" loading="lazy">}
                {(item.category || item.contentTypeLabel) && (
                  <span class="article-card__tag">{item.category || item.contentTypeLabel}</span>
                )}
              </div>
              <span class="article-card__date">{item.date}</span>
              <h3 class="article-card__title">{item.title}</h3>
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>

  <script is:inline>
    document.querySelector('.mobile-menu-toggle').addEventListener('click', function() {
      const expanded = this.getAttribute('aria-expanded') === 'true';
      this.setAttribute('aria-expanded', !expanded);
      document.getElementById('nav-menu').classList.toggle('nav-links--open', !expanded);
    });
  </script>

  <script is:inline>
    (function() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.querySelectorAll('[data-reveal]').forEach(function(el) { el.classList.add('revealed'); });
        return;
      }
      document.querySelectorAll('[data-reveal-stagger]').forEach(function(container) {
        var children = container.querySelectorAll(':scope > [data-reveal]');
        children.forEach(function(child, i) {
          if (!child.style.getPropertyValue('--delay')) { child.style.setProperty('--delay', (i * 0.1) + 's'); }
        });
      });
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) { entry.target.classList.add('revealed'); observer.unobserve(entry.target); }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
      document.querySelectorAll('[data-reveal]').forEach(function(el) { observer.observe(el); });
    })();
  </script>
<style is:global>
/* ----- Active nav link ----- */
.nav-link--active {
  background-color: var(--color-black-5);
}

/* ----- Insights Hero ----- */
.insights-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-32);
  padding: var(--space-64) var(--space-72);
}

.insights-hero__text {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-16);
  max-width: 646px;
  text-align: center;
}

.insights-hero__title {
  font-size: var(--text-5xl);
  font-weight: var(--weight-regular);
  line-height: var(--leading-tight);
  color: var(--color-neutral-900);
}

.insights-hero__subtitle {
  font-size: var(--text-lg);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--color-neutral-900);
}

/* ----- Filter Tags ----- */
.insights-hero__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-12);
  justify-content: center;
  max-width: 870px;
}

.tag {
  background-color: var(--color-white);
  border: 1px solid var(--color-neutral-200);
  border-radius: var(--radius-md);
  padding: var(--space-4) var(--space-12);
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--weight-regular);
  line-height: var(--leading-normal);
  color: var(--color-neutral-900);
  white-space: nowrap;
  cursor: pointer;
  box-shadow: var(--shadow-sm);
  transition: background-color 0.15s ease;
}

.tag:hover {
  background-color: var(--color-neutral-50);
}

.tag--active {
  background-color: var(--color-orange-300);
}

.tag--active:hover {
  background-color: #ffa94d;
}

/* ----- Articles Section ----- */
.articles {
  display: flex;
  flex-direction: column;
  gap: var(--space-32);
  padding: 0 var(--space-72) var(--space-64);
}

.articles__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.articles__title {
  font-size: var(--text-4xl);
  font-weight: var(--weight-regular);
  line-height: var(--leading-snug);
  color: var(--color-neutral-900);
}

.articles__sort {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  background-color: var(--color-white);
  border: 1px solid var(--color-neutral-300);
  border-radius: var(--radius-md);
  padding: var(--space-12) var(--space-12) var(--space-12) var(--space-16);
  font-size: var(--text-base);
  line-height: 0;
  cursor: pointer;
}

.articles__sort-label {
  color: var(--color-neutral-500);
  line-height: var(--leading-normal);
}

.articles__sort-value {
  color: var(--color-neutral-900);
  line-height: var(--leading-normal);
}

.articles__sort-icon {
  width: 20px;
  height: 20px;
  color: var(--color-neutral-900);
  transform: rotate(90deg);
}

/* ----- Article Grid ----- */
.article-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-48);
}

/* ----- Article Card ----- */
.article-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
  text-decoration: none;
  color: inherit;
}

.article-card__image-wrap {
  position: relative;
  aspect-ratio: 408 / 320;
  border-radius: var(--radius-xl);
  overflow: hidden;
  background-color: var(--color-neutral-100, #f3f4f6);
}

.article-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.article-card:hover .article-card__image {
  transform: scale(1.03);
}

.article-card__tag {
  position: absolute;
  top: 14px;
  left: 13px;
  background-color: var(--color-white);
  border: 1px solid var(--color-neutral-200);
  border-radius: var(--radius-md);
  padding: var(--space-4) var(--space-12);
  font-size: var(--text-sm);
  font-weight: var(--weight-regular);
  line-height: var(--leading-normal);
  color: var(--color-neutral-900);
  box-shadow: var(--shadow-sm);
}

.article-card__date {
  font-size: var(--text-lg);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--color-neutral-500);
}

.article-card__title {
  font-size: var(--text-2xl);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--color-neutral-900);
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ----- Responsive ----- */
@media (max-width: 1024px) {
  .article-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-32);
  }

  .articles {
    padding-left: var(--space-32);
    padding-right: var(--space-32);
  }

  .insights-hero {
    padding-left: var(--space-32);
    padding-right: var(--space-32);
  }
}

@media (max-width: 640px) {
  .article-grid {
    grid-template-columns: 1fr;
    gap: var(--space-32);
  }

  .insights-hero__title {
    font-size: var(--text-4xl);
  }

  .articles__title {
    font-size: var(--text-3xl);
  }

  .articles__header {
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-16);
  }

  .articles {
    padding-left: var(--space-24);
    padding-right: var(--space-24);
  }

  .insights-hero {
    padding-left: var(--space-24);
    padding-right: var(--space-24);
  }
}
</style>
</BaseLayout>
