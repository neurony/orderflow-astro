  <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('[id$="-lead-form"]').forEach(function(form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          var prefix = form.id.replace('-lead-form', '');
          var email = form.querySelector('[name="email"]').value.trim();
          var company = form.querySelector('[name="company"]').value.trim();
          var termsInput = form.querySelector('[name="terms"]');
          var termsLabel = termsInput.closest('.cta__checkbox');
          termsLabel.classList.remove('cta__checkbox--error');
          if (!termsInput.checked) {
            termsLabel.classList.add('cta__checkbox--error');
            return;
          }
          if (!email || !company) return;

          document.getElementById(prefix + '-form-step').style.display = 'none';
          var calendlyStep = document.getElementById(prefix + '-calendly-step');
          calendlyStep.style.display = 'block';

          var widgetEl = document.getElementById(prefix + '-calendly-widget');
          var calendlyUrl = 'https://calendly.com/management-neurony/introductory-meeting-with-orderflow?hide_event_type_details=1&hide_gdpr_banner=1'
            + '&email=' + encodeURIComponent(email)
            + '&a1=' + encodeURIComponent(company);
          widgetEl.classList.add('calendly-inline-widget');
          widgetEl.setAttribute('data-url', calendlyUrl);
          widgetEl.style.minWidth = '320px';
          widgetEl.style.height = '600px';
          Calendly.initInlineWidget({
            url: calendlyUrl,
            parentElement: widgetEl,
            prefill: {
              email: email,
              customAnswers: {
                a1: company
              }
            }
          });
        });
      });
    });
  </script>
</BaseLayout>
