---
import BaseLayout from '../layouts/BaseLayout.astro';

const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Orderflow',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web-based',
  description: 'AI-powered order processing automation that converts emails, WhatsApp messages, PDFs, scans, and handwritten notes into structured ERP-ready data.',
  url: 'https://orderflow.com',
  screenshot: 'https://orderflow.com/images/how-it-works.jpg',
  featureList: [
    'Multi-format order processing',
    'AI-powered SKU matching',
    'WhatsApp order capture',
    'Handwritten note recognition',
    'ERP integration',
  ],
  offers: {
    '@type': 'Offer',
    priceCurrency: 'EUR',
    availability: 'https://schema.org/OnlineOnly',
  },
  publisher: { '@id': 'https://orderflow.com/#organization' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does Orderflow process orders from different formats?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Orderflow monitors your email and WhatsApp continuously, extracting all relevant information from messages, PDFs, scans, and handwritten notes the moment they arrive. It then matches products to your catalog and delivers ERP-ready data automatically.',
      },
    },
    {
      '@type': 'Question',
      name: 'What accuracy does Orderflow achieve?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Approximately 98% of orders are processed without any manual modification, with 80%+ of orders fully or partially product-mapped on first pass. Accuracy improves over time as the system learns.',
      },
    },
  ],
};
---

<BaseLayout
  title="Orderflow — Stop manually processing orders | AI Order Automation"
  description="Orderflow automates order processing for distribution businesses. Convert emails, WhatsApp, PDFs, scans and handwritten notes into ERP-ready data. ~98% accuracy."
  ogImage="/images/og-default.jpg"
  jsonLd={[softwareAppSchema, faqSchema]}
>
  <main>

    <!-- =============================================
         HERO SECTION
         ============================================= -->
    <section class="section section--hero" aria-labelledby="hero-heading">
      <div class="section__card section__card--muted">
        <div class="hero__text">
          <h1 id="hero-heading" class="hero__title" data-reveal="up">Stop manually processing orders</h1>
          <p class="hero__subtitle" data-reveal="up" style="--delay:0.1s">Every order, any format, automated.</p>
          <div class="hero__cta" data-reveal="up" style="--delay:0.2s">
            <a href="/demo" class="btn btn--dark">See it in action</a>
          </div>
        </div>

        <!-- Hero visual: floating format cards -->
        <div class="hero__visual" aria-label="Order formats Orderflow can process">
          <div class="hero__badges-mobile" aria-hidden="true">
