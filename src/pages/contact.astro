---
import BaseLayout from '../layouts/BaseLayout.astro';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Orderflow',
  description: 'Get in touch with the Orderflow team. Schedule a demo or ask questions about AI-powered order processing.',
  url: 'https://orderflow.com/contact',
  mainEntity: {
    '@type': 'Organization',
    '@id': 'https://orderflow.com/#organization',
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: '+40-722-481-305',
      email: 'contact@orderflow.com',
      contactType: 'sales',
      availableLanguage: ['English', 'Romanian', 'German'],
    },
  },
};
---

<BaseLayout
  title="Contact Us — Orderflow | Book a Demo Call"
  description="Get in touch with the Orderflow team. Schedule a demo of AI-powered order processing for your distribution business."
  canonical="https://orderflow.com/contact"
  jsonLd={contactSchema}
>
  <main>
    <!-- Ticker bar -->
    <div class="ticker" aria-label="Scrolling announcements">
      <span class="ticker__text">Automating order intake for distribution businesses across Romania.</span>
      <img src="/contact/logomark.svg" alt="" class="ticker__icon" aria-hidden="true">
      <span class="ticker__text">Booked by 10 companies this week</span>
      <img src="/contact/logomark.svg" alt="" class="ticker__icon" aria-hidden="true">
      <span class="ticker__text">Automating order intake for distribution businesses across Romania.</span>
    </div>

    <!-- Contact Hero -->
    <section class="section section--contact-hero" aria-labelledby="contact-heading">
      <div class="contact-hero">
        <div class="contact-hero__left">
          <img src="/contact/logomark.svg" alt="" class="contact-hero__logomark" aria-hidden="true">
          <h1 id="contact-heading" class="contact-hero__title" data-reveal="up">Ready to stop processing orders by hand?</h1>
          <p class="contact-hero__subtitle" data-reveal="up" style="--delay:0.1s">Book a call and see <strong>Orderflow</strong> running on real order data.</p>
          <div class="contact-hero__badges" data-reveal="up" style="--delay:0.2s">
            <a href="tel:+40722481305" class="contact-badge">
              <img src="/contact/icon-phone.svg" alt="" class="contact-badge__icon">
              <span class="contact-badge__text">+40 0722 481 305</span>
            </a>
            <a href="mailto:contact@orderflow.com" class="contact-badge">
              <span class="contact-badge__icon" style="background-color: var(--color-blue-400); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center;">
                <svg width="20" height="14" viewBox="0 0 20 14" fill="none"><path d="M1 1L10 7.5L19 1" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><rect x="0.5" y="0.5" width="19" height="13" rx="2" stroke="white" stroke-width="1"/></svg>
              </span>
              <span class="contact-badge__text">contact@orderflow.com</span>
            </a>
          </div>
        </div>

        <div class="contact-hero__right" data-reveal="up" style="--delay:0.3s">
          <div class="expert-badge">
            <img src="/contact/maria-avatar.png" alt="Maria, product expert" class="expert-badge__avatar">
            <img src="/contact/cursor-arrow.svg" alt="" class="expert-badge__cursor" aria-hidden="true">
            <div class="expert-badge__tag">
              <span class="expert-badge__name">Maria</span>
              <span class="expert-badge__role">Product expert</span>
            </div>
          </div>

          <div class="form-card">
            <div id="contact-form-step" class="calendly-form-step">
              <p class="form-card__heading">One of our experts will walk you through the product and answer your questions.</p>
              <form id="contact-lead-form" novalidate>
                <div class="form-input">
                  <label class="form-input__label" for="email">Business email</label>
                  <input type="email" id="email" name="email" class="form-input__field" placeholder="Type in your business email address" required>
                </div>
                <div class="form-input">
                  <label class="form-input__label" for="company">Company name</label>
                  <input type="text" id="company" name="company" class="form-input__field" placeholder="Type in your company name" required>
                </div>
                <label class="form-checkbox">
                  <input type="checkbox" class="form-checkbox__input" name="agree" required>
                  <span class="form-checkbox__text">I agree with the <a href="/terms">Terms &amp; Conditions</a> and the <a href="/privacy">Privacy Policy.</a></span>
                </label>
                <button type="submit" class="btn btn--dark">Schedule a demo</button>
              </form>
            </div>
            <div id="contact-calendly-step" class="calendly-form-step" style="display:none;">
              <div id="contact-calendly-widget" style="min-height:400px;"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('[id$="-lead-form"]').forEach(function(form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          var prefix = form.id.replace('-lead-form', '');
          var email = form.querySelector('[name="email"]').value.trim();
          var company = form.querySelector('[name="company"]').value.trim();
          var termsInput = form.querySelector('[name="agree"]') || form.querySelector('[name="terms"]');
          var termsLabel = termsInput.closest('.form-checkbox') || termsInput.closest('.cta__checkbox');
          termsLabel.classList.remove('form-checkbox--error', 'cta__checkbox--error');
          if (!termsInput.checked) {
            termsLabel.classList.add(termsLabel.classList.contains('form-checkbox') ? 'form-checkbox--error' : 'cta__checkbox--error');
            return;
          }
          if (!email || !company) return;

          document.getElementById(prefix + '-form-step').style.display = 'none';
          var calendlyStep = document.getElementById(prefix + '-calendly-step');
          calendlyStep.style.display = 'block';

          var widgetEl = document.getElementById(prefix + '-calendly-widget');
          var calendlyUrl = 'https://calendly.com/management-neurony/introductory-meeting-with-orderflow?hide_event_type_details=1&hide_gdpr_banner=1'
            + '&email=' + encodeURIComponent(email)
            + '&a1=' + encodeURIComponent(company);
          widgetEl.classList.add('calendly-inline-widget');
          widgetEl.setAttribute('data-url', calendlyUrl);
          widgetEl.style.minWidth = '320px';
          widgetEl.style.height = '400px';
          Calendly.initInlineWidget({
            url: calendlyUrl,
            parentElement: widgetEl,
            prefill: {
              email: email,
              customAnswers: {
                a1: company
              }
            }
          });
        });
      });
    });
  </script>

  <script is:inline>
    document.querySelector('.mobile-menu-toggle').addEventListener('click', function() {
      const expanded = this.getAttribute('aria-expanded') === 'true';
      this.setAttribute('aria-expanded', !expanded);
      document.getElementById('nav-menu').classList.toggle('nav-links--open', !expanded);
    });
  </script>

  <script is:inline>
    (function() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.querySelectorAll('[data-reveal]').forEach(function(el) { el.classList.add('revealed'); });
        return;
      }
      document.querySelectorAll('[data-reveal-stagger]').forEach(function(container) {
        var children = container.querySelectorAll(':scope > [data-reveal]');
        children.forEach(function(child, i) {
          if (!child.style.getPropertyValue('--delay')) { child.style.setProperty('--delay', (i * 0.1) + 's'); }
        });
      });
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) { entry.target.classList.add('revealed'); observer.unobserve(entry.target); }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
      document.querySelectorAll('[data-reveal]').forEach(function(el) { observer.observe(el); });
    })();
  </script>
<style is:global>
/* ----- Active nav link ----- */
.nav-link--active {
  background-color: var(--color-black-5);
}

/* ----- Ticker Bar ----- */
.ticker {
  background-color: var(--color-neutral-900);
  border: 1px solid var(--color-neutral-200);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-8);
  padding: var(--space-12) var(--space-24);
  height: 64px;
  overflow: hidden;
  white-space: nowrap;
  width: 100%;
}

.ticker__text {
  font-size: var(--text-xl);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--color-white);
  white-space: nowrap;
}

.ticker__icon {
  width: 24px;
  height: 24px;
  flex-shrink: 0;
}

/* ----- Contact Hero ----- */
.contact-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-32) var(--space-72) 0;
  background-color: var(--color-white);
  border-radius: var(--radius-xl);
  overflow: visible;
}

.contact-hero__left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
  max-width: 534px;
}

.contact-hero__logomark {
  width: 48px;
  height: 48px;
}

.contact-hero__title {
  font-size: var(--text-5xl);
  font-weight: var(--weight-regular);
  line-height: var(--leading-tight);
  color: var(--color-neutral-900);
}

.contact-hero__subtitle {
  font-size: var(--text-lg);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--color-neutral-900);
}

.contact-hero__subtitle strong {
  font-weight: var(--weight-semibold);
}

/* Contact info badges */
.contact-hero__badges {
  display: flex;
  gap: var(--space-16);
  align-items: center;
  padding-top: var(--space-16);
}

.contact-badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-4);
  background-color: var(--color-white);
  border: 1px solid var(--color-neutral-200);
  border-radius: var(--radius-md);
  padding: var(--space-4) var(--space-12) var(--space-4) var(--space-4);
  box-shadow: var(--shadow-sm);
  text-decoration: none;
  color: var(--color-neutral-900);
  transition: box-shadow 0.15s ease;
}

.contact-badge:hover {
  box-shadow: var(--shadow-md);
}

.contact-badge__icon {
  width: 32px;
  height: 32px;
  flex-shrink: 0;
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.contact-badge__text {
  font-size: var(--text-lg);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--color-neutral-900);
}

/* ----- Form Card (right side) ----- */
.contact-hero__right {
  width: 718px;
  flex-shrink: 0;
  background-color: var(--color-orange-300);
  border: 1.5px solid var(--color-neutral-200);
  border-radius: var(--radius-xl);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 var(--space-72) var(--space-64);
  position: relative;
  overflow: hidden;
  min-height: 400px;
}

/* Expert badge floating above form */
.expert-badge {
  display: flex;
  align-items: flex-start;
  gap: 0;
  margin-bottom: -16px;
  position: relative;
  z-index: 2;
}

.expert-badge__avatar {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-full);
  border: 3px solid var(--color-orange-300);
  object-fit: cover;
  flex-shrink: 0;
}

.expert-badge__cursor {
  width: 22px;
  height: 32px;
  margin-top: 50px;
  margin-left: -10px;
}

.expert-badge__tag {
  background-color: var(--color-purple-600);
  border-radius: var(--radius-sm);
  padding: var(--space-4) var(--space-8);
  display: flex;
  align-items: center;
  gap: var(--space-4);
  box-shadow: var(--shadow-sm);
  margin-top: 28px;
  margin-left: 4px;
  white-space: nowrap;
}

.expert-badge__name {
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  line-height: var(--leading-normal);
  color: var(--color-white);
}

.expert-badge__role {
  font-size: var(--text-sm);
  font-weight: var(--weight-regular);
  line-height: var(--leading-normal);
  color: rgba(255, 255, 255, 0.8);
}

/* The white form panel */
.form-card {
  background-color: var(--color-white);
  border: 1.5px solid var(--color-neutral-200);
  border-radius: var(--radius-xl);
  padding: var(--space-32);
  display: flex;
  flex-direction: column;
  gap: var(--space-24);
  width: 472px;
  box-shadow: var(--shadow-md), 32px 32px 1px 0px var(--color-black-10);
  position: relative;
}

.form-card form {
  display: flex;
  flex-direction: column;
  gap: var(--space-24);
  z-index: 1;
}

.form-card__heading {
  font-size: var(--text-2xl);
  font-weight: var(--weight-semibold);
  line-height: var(--leading-relaxed);
  color: var(--color-neutral-900);
}

/* Form inputs */
.form-input {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  background-color: var(--color-white);
  border: 1.5px solid var(--color-neutral-200);
  border-radius: var(--radius-lg);
  padding: var(--space-8) var(--space-12);
  width: 100%;
  transition: border-color 0.15s ease;
}

.form-input:focus-within {
  border-color: var(--color-neutral-900);
}

.form-input__label {
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  line-height: var(--leading-normal);
  color: var(--color-neutral-900);
}

.form-input__field {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--weight-regular);
  line-height: var(--leading-normal);
  color: var(--color-neutral-900);
  border: none;
  outline: none;
  background: transparent;
  padding: 0;
  width: 100%;
}

.form-input__field::placeholder {
  color: var(--color-neutral-500);
}

/* Checkbox */
.form-checkbox {
  display: flex;
  align-items: center;
  gap: var(--space-12);
  padding: var(--space-12) 0;
  cursor: pointer;
}

.form-checkbox__input {
  appearance: none;
  -webkit-appearance: none;
  width: 20px;
  height: 20px;
  flex-shrink: 0;
  background-color: var(--color-neutral-100);
  border: 1.5px solid var(--color-neutral-200);
  border-radius: 4px;
  cursor: pointer;
  position: relative;
}

.form-checkbox__input:checked {
  background-color: var(--color-neutral-900);
  border-color: var(--color-neutral-900);
}

.form-checkbox__input:checked::after {
  content: '';
  position: absolute;
  left: 5px;
  top: 2px;
  width: 6px;
  height: 10px;
  border: solid white;
  border-width: 0 2px 2px 0;
  transform: rotate(45deg);
}

.form-checkbox__text {
  font-size: var(--text-sm);
  font-weight: var(--weight-regular);
  line-height: var(--leading-normal);
  color: var(--color-neutral-900);
}

.form-checkbox__text a {
  text-decoration: underline;
  text-underline-offset: 2px;
}

.form-checkbox__text a:hover {
  color: var(--color-neutral-700);
}

.form-checkbox--error .form-checkbox__text {
  color: #dc2626;
}

.form-checkbox--error .form-checkbox__input {
  border-color: #dc2626;
}

/* ----- Responsive ----- */
@media (max-width: 1280px) {
  .contact-hero__right {
    width: 560px;
    min-height: 600px;
    padding: 0 var(--space-48) var(--space-48);
  }

  .form-card {
    width: 100%;
    max-width: 440px;
  }
}

@media (max-width: 1024px) {
  .contact-hero {
    flex-direction: column;
    gap: var(--space-48);
    padding: var(--space-48) var(--space-32);
  }

  .contact-hero__left {
    max-width: 100%;
    align-items: center;
    text-align: center;
  }

  .contact-hero__badges {
    justify-content: center;
  }

  .contact-hero__right {
    width: 100%;
    min-height: auto;
    padding: var(--space-32) var(--space-32) var(--space-48);
  }

  .form-card {
    width: 100%;
    max-width: 472px;
  }

  .ticker {
    flex-wrap: nowrap;
    overflow: hidden;
  }
}

@media (max-width: 640px) {
  .contact-hero {
    padding: var(--space-32) var(--space-24);
  }

  .contact-hero__title {
    font-size: var(--text-4xl);
  }

  .contact-hero__badges {
    flex-direction: column;
    align-items: stretch;
  }

  .contact-badge {
    justify-content: center;
  }

  .contact-hero__right {
    padding: var(--space-24) var(--space-16) var(--space-32);
  }

  .form-card {
    padding: var(--space-24);
  }

  .expert-badge {
    transform: scale(0.85);
  }
}
</style>
</BaseLayout>
