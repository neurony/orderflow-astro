---
import BaseLayout from '../layouts/BaseLayout.astro';

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Orderflow',
  description: 'Orderflow is an AI-powered order processing platform built by Neurony Solutions, a team with 18 years of experience and 800+ delivered projects.',
  url: 'https://orderflow.com/about',
  mainEntity: {
    '@type': 'Organization',
    '@id': 'https://orderflow.com/#organization',
    name: 'Orderflow',
    url: 'https://orderflow.com',
    foundingDate: '2024',
    parentOrganization: {
      '@type': 'Organization',
      name: 'Neurony Solutions SRL',
      url: 'https://neurony.ro',
      foundingDate: '2007',
      numberOfEmployees: {
        '@type': 'QuantitativeValue',
        minValue: 30,
      },
      description: '18 years in tech, 800+ projects delivered, 83+ clients served.',
    },
    areaServed: [
      { '@type': 'Country', name: 'Romania' },
      { '@type': 'Country', name: 'Germany' },
      { '@type': 'Country', name: 'Austria' },
      { '@type': 'Country', name: 'Switzerland' },
    ],
    contactPoint: {
      '@type': 'ContactPoint',
      email: 'contact@orderflow.com',
      contactType: 'sales',
      availableLanguage: ['English', 'Romanian', 'German'],
    },
  },
};
---

<BaseLayout
  title="About Us — Orderflow | AI Order Processing by Neurony Solutions"
  description="Orderflow is built by Neurony Solutions — 18 years in tech, 800+ projects. We automate order processing for distribution businesses across Europe."
  canonical="https://orderflow.com/about"
  jsonLd={aboutPageSchema}
>
  <main>

    <!-- =============================================
         HERO SECTION
         ============================================= -->
    <section class="section section--about-hero" aria-labelledby="about-hero-heading">
      <div class="section__card section__card--muted">
        <div class="about-hero">
          <div class="about-hero__logomark" data-reveal="up">
            <svg width="64" height="64" viewBox="0 0 56 56" fill="none" aria-hidden="true">
              <rect width="56" height="56" rx="16" fill="#FFD230"/>
              <path fill-rule="evenodd" clip-rule="evenodd" d="M18.5166 28.9213H11.9504L11.95 29.0552C11.95 32.4778 12.6467 35.5225 14.0394 38.1889C15.4719 40.8553 17.4612 42.9454 20.0081 44.4577C22.555 45.9302 25.5596 46.6666 29.0217 46.6666C32.4837 46.6666 35.4883 45.9301 38.0352 44.4577C40.5822 42.9454 42.5518 40.8553 43.9447 38.1889C45.3772 35.5224 46.0943 32.4778 46.0943 29.0552C46.0943 25.5929 45.3772 22.5288 43.9447 19.8624C42.5518 17.196 40.5822 15.1068 38.0352 13.5945C35.6045 12.1511 32.7568 11.396 29.4921 11.3301V17.1839C31.4795 17.2507 33.1937 17.7453 34.6333 18.6682C36.1851 19.6233 37.379 20.9965 38.2147 22.7873C39.0504 24.5781 39.468 26.6675 39.468 29.0552C39.468 31.4032 39.0504 33.4731 38.2147 35.2639C37.379 37.0149 36.1851 38.3881 34.6333 39.383C33.0812 40.3382 31.2104 40.8159 29.0217 40.8159C26.8332 40.8158 24.9425 40.3382 23.3508 39.383C21.799 38.3881 20.6051 37.0149 19.7694 35.2639C18.9338 33.4731 18.5161 31.4032 18.5161 29.0552L18.5166 28.9213Z" fill="#101828"/>
              <path d="M26.6941 26.1232L11.9758 26.1232L11.9758 21.5941L18.9631 21.5941L9.90564 12.5359L13.1079 9.3334L22.1654 18.3915L22.1654 11.4037L26.6941 11.4037L26.6941 26.1232Z" fill="white"/>
            </svg>
          </div>
          <p class="about-hero__eyebrow" data-reveal="up" style="--delay:0.05s">About Orderflow</p>
          <h1 id="about-hero-heading" class="about-hero__title" data-reveal="up" style="--delay:0.1s">We believe no order should wait on a human to retype it.</h1>
          <p class="about-hero__subtitle" data-reveal="up" style="--delay:0.2s">Orderflow exists because distribution businesses deserve technology that adapts to their customers, not the other way around.</p>
          <div class="about-hero__badges" data-reveal="up" style="--delay:0.3s">
            <span class="about-hero__badge">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="10" fill="#00A63E"/><path d="M6.25 10L8.75 12.5L13.75 7.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Production-tested
            </span>
            <span class="about-hero__badge">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="10" fill="#00A63E"/><path d="M6.25 10L8.75 12.5L13.75 7.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Built by Neurony
            </span>
            <span class="about-hero__badge">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="10" fill="#00A63E"/><path d="M6.25 10L8.75 12.5L13.75 7.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              GDPR compliant
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- =============================================
         OUR STORY
         ============================================= -->
    <section class="section section--about-story" aria-labelledby="story-heading">
      <div class="section__card section__card--white">
        <div class="about-story">
          <div class="about-story__content" data-reveal="up">
            <h2 id="story-heading" class="about-story__title">How Orderflow came to be</h2>
            <p class="about-story__text">For 18 years, <a href="https://neurony.ro" target="_blank" rel="noopener noreferrer">Neurony Solutions</a> has been building technology that solves real business problems. Across 800+ projects and 83+ clients, we kept seeing the same bottleneck in distribution: order intake.</p>
            <p class="about-story__text">Companies were growing, but their order desks weren't scaling. Teams were spending hours retyping emails, deciphering handwritten notes, and manually matching vague product descriptions to catalog entries. Every new customer or channel added more pressure on the same people.</p>
            <p class="about-story__text">We knew AI could do better. Not to replace the people who understand the business, but to handle the repetitive work that was holding them back. So we built Orderflow: a system that reads orders in any format, maps products to your catalog, and delivers clean, ERP-ready data without manual intervention.</p>
          </div>
          <div class="about-story__image-wrap" data-reveal="up" style="--delay:0.2s">
            <img src="/images/how-it-works.jpg" alt="Orderflow dashboard showing order processing pipeline" class="about-story__image">
          </div>
        </div>
      </div>
    </section>

    <!-- =============================================
         VALUES
         ============================================= -->
    <section class="section section--about-values" aria-labelledby="values-heading">
      <div class="section__card section__card--purple">
        <h2 id="values-heading" class="section__heading section__heading--center" data-reveal="up">What drives us</h2>
        <div class="about-values" data-reveal-stagger>
          <article class="about-value" data-reveal="up">
            <div class="about-value__icon">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
                <rect width="40" height="40" rx="10" fill="#FFD230" fill-opacity="0.15"/>
                <path d="M13 20L17 24L27 14" stroke="#FE9A00" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M20 11C15.029 11 11 15.029 11 20C11 24.971 15.029 29 20 29C24.971 29 29 24.971 29 20C29 15.029 24.971 11 20 11Z" stroke="#FE9A00" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="about-value__title">We automate complexity</h3>
            <p class="about-value__text">Your customers send orders however is easiest for them. We handle the chaos so your team doesn't have to.</p>
          </article>
          <article class="about-value" data-reveal="up">
            <div class="about-value__icon">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
                <rect width="40" height="40" rx="10" fill="#E0E7FF" fill-opacity="0.5"/>
                <path d="M20 13V20L24 24" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="20" cy="20" r="9" stroke="#4F46E5" stroke-width="2"/>
                <path d="M15 27L13 29M25 27L27 29" stroke="#4F46E5" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="about-value__title">We keep humans in control</h3>
            <p class="about-value__text">AI processes, humans verify. Low-confidence matches are flagged, not guessed. Your team stays in the loop without touching every order.</p>
          </article>
          <article class="about-value" data-reveal="up">
            <div class="about-value__icon">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
                <rect width="40" height="40" rx="10" fill="#D1FAE5" fill-opacity="0.5"/>
                <path d="M14 26L18 22L21 25L26 18" stroke="#00A63E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M23 18H26V21" stroke="#00A63E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="11" y="11" width="18" height="18" rx="3" stroke="#00A63E" stroke-width="2"/>
              </svg>
            </div>
            <h3 class="about-value__title">We learn from every order</h3>
            <p class="about-value__text">Orderflow gets smarter the longer it runs. Product mapping precision increases over time, making the system more reliable with each order processed.</p>
          </article>
          <article class="about-value" data-reveal="up">
            <div class="about-value__icon">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
                <rect width="40" height="40" rx="10" fill="#FEE2E2" fill-opacity="0.5"/>
                <path d="M16 20H24M20 16V24" stroke="#DC2626" stroke-width="2" stroke-linecap="round"/>
                <circle cx="14" cy="14" r="3" stroke="#DC2626" stroke-width="1.5"/>
                <circle cx="26" cy="26" r="3" stroke="#DC2626" stroke-width="1.5"/>
                <path d="M16.5 15.5L23.5 24.5" stroke="#DC2626" stroke-width="1.5" stroke-dasharray="2 2"/>
              </svg>
            </div>
            <h3 class="about-value__title">We integrate, not replace</h3>
            <p class="about-value__text">Orderflow plugs into your existing workflow. Same email inbox, same ERP, same team. Just less manual work and fewer errors.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- =============================================
         CREDIBILITY / STATS
         ============================================= -->
    <section class="section section--about-stats" aria-labelledby="stats-heading">
      <div class="section__card section__card--white">
        <h2 id="stats-heading" class="section__heading section__heading--center" data-reveal="up">Production-tested, not theoretical</h2>
        <p class="about-stats__subtitle" data-reveal="up" style="--delay:0.1s">Orderflow has been running in production at a high-volume distribution business. These numbers are drawn from real orders and real operational conditions.</p>
        <ul class="about-stats-grid" role="list" data-reveal-stagger>
          <li class="about-stat" data-reveal="up">
            <div class="about-stat__image about-stat__image--q1" aria-hidden="true"></div>
            <div class="about-stat__content">
              <span class="about-stat__number">~98%</span>
              <span class="about-stat__label">of orders processed without manual modification</span>
            </div>
          </li>
          <li class="about-stat" data-reveal="up">
            <div class="about-stat__image about-stat__image--q2" aria-hidden="true"></div>
            <div class="about-stat__content">
              <span class="about-stat__number">80%+</span>
              <span class="about-stat__label">product mapping accuracy on first pass</span>
            </div>
          </li>
          <li class="about-stat" data-reveal="up">
            <div class="about-stat__image about-stat__image--q3" aria-hidden="true"></div>
            <div class="about-stat__content">
              <span class="about-stat__number">18 yrs</span>
              <span class="about-stat__label">of Neurony engineering experience behind the product</span>
            </div>
          </li>
          <li class="about-stat" data-reveal="up">
            <div class="about-stat__image about-stat__image--q4" aria-hidden="true"></div>
            <div class="about-stat__content">
              <span class="about-stat__number">800+</span>
              <span class="about-stat__label">projects delivered by the team that built Orderflow</span>
            </div>
          </li>
        </ul>
      </div>
    </section>

    <!-- =============================================
         TEAM / NEURONY
         ============================================= -->
    <section class="section section--about-team" aria-labelledby="team-heading">
      <div class="section__card section__card--muted">
        <div class="about-team" data-reveal="up">
          <h2 id="team-heading" class="about-team__title">Built by Neurony Solutions</h2>
          <p class="about-team__text">Orderflow is developed and maintained by <a href="https://neurony.ro" target="_blank" rel="noopener noreferrer">Neurony Solutions</a>, a Romanian software company with a 30+ person engineering team. For nearly two decades, Neurony has delivered enterprise-grade solutions for clients across Europe.</p>
          <p class="about-team__text">From AI and machine learning to full-stack platforms, Neurony brings the depth of experience needed to build products that work under real-world conditions, not just in demos.</p>
          <div class="about-team__cta">
            <a href="https://neurony.ro" target="_blank" rel="noopener noreferrer" class="btn btn--outline">Learn more about Neurony</a>
          </div>
        </div>
      </div>
    </section>

    <!-- =============================================
         CTA BANNER (same as homepage)
         ============================================= -->
    <section class="section section--cta" aria-labelledby="about-cta-heading">
      <div class="section__card section__card--dark">
        <div class="cta__ticker">
          <div class="cta__ticker-inner">
            <span>Automating order intake for distribution businesses across Romania.</span>
            <img src="/images/logomark-small.svg" alt="" class="cta__ticker-logo">
            <span>Booked by 10 companies this week</span>
            <img src="/images/logomark-small.svg" alt="" class="cta__ticker-logo">
            <span>Automating order intake for distribution businesses across Romania.</span>
            <img src="/images/logomark-small.svg" alt="" class="cta__ticker-logo">
            <span>Booked by 10 companies this week</span>
            <img src="/images/logomark-small.svg" alt="" class="cta__ticker-logo">
            <span>Automating order intake for distribution businesses across Romania.</span>
            <img src="/images/logomark-small.svg" alt="" class="cta__ticker-logo">
            <span>Booked by 10 companies this week</span>
            <img src="/images/logomark-small.svg" alt="" class="cta__ticker-logo">
          </div>
        </div>
        <div class="cta__layout">
          <div class="cta__left">
            <img src="/images/logomark.svg" alt="" class="cta__logo" width="48" height="48">
            <h2 id="about-cta-heading" class="cta__title" data-reveal="up">Ready to stop processing orders by hand?</h2>
            <p class="cta__subtitle">Book a call and see <strong>Orderflow</strong> running on real order data.</p>
          </div>
          <div class="cta__right">
            <div class="cta__form-card" data-reveal="right">
              <div id="about-cta-form-step" class="calendly-form-step">
                <p class="cta__form-heading">One of our experts will walk you through the product and answer your questions.</p>
                <form id="about-cta-lead-form" novalidate>
                  <div class="cta__input"><label class="cta__input-label" for="about-cta-email">Business email</label><input type="email" id="about-cta-email" name="email" class="cta__input-field" placeholder="Type in your business email address" required></div>
                  <div class="cta__input"><label class="cta__input-label" for="about-cta-company">Company name</label><input type="text" id="about-cta-company" name="company" class="cta__input-field" placeholder="Type in your company name" required></div>
                  <div class="cta__checkbox"><input type="checkbox" id="about-cta-terms" name="terms" class="cta__checkbox-input" required><label class="cta__checkbox-text" for="about-cta-terms">I agree with the <a href="/terms">Terms &amp; Conditions</a> and the <a href="/privacy">Privacy Policy</a>.</label></div>
                  <button type="submit" class="btn btn--primary">Schedule a demo</button>
                </form>
              </div>
              <div id="about-cta-calendly-step" class="calendly-form-step" style="display:none;">
                <div id="about-cta-calendly-widget" style="min-height:700px;"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('[id$="-lead-form"]').forEach(function(form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          var prefix = form.id.replace('-lead-form', '');
          var email = form.querySelector('[name="email"]').value.trim();
          var company = form.querySelector('[name="company"]').value.trim();
          var terms = form.querySelector('[name="terms"]').checked;
          if (!email || !company || !terms) return;

          document.getElementById(prefix + '-form-step').style.display = 'none';
          var calendlyStep = document.getElementById(prefix + '-calendly-step');
          calendlyStep.style.display = 'block';

          Calendly.initInlineWidget({
            url: 'https://calendly.com/management-neurony/introductory-meeting',
            parentElement: document.getElementById(prefix + '-calendly-widget'),
            prefill: {
              email: email,
              customAnswers: {
                a1: company
              }
            }
          });
        });
      });
    });
  </script>

  <style is:global>
    /* =============================================
       ABOUT — HERO
       ============================================= */
    .about-hero {
      text-align: center;
      max-width: 800px;
      margin: 0 auto;
      padding: var(--space-72) var(--space-24);
    }

    .about-hero__logomark {
      margin-bottom: var(--space-24);
    }

    .about-hero__badges {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-16);
      margin-top: var(--space-32);
      flex-wrap: wrap;
    }

    .about-hero__badge {
      display: inline-flex;
      align-items: center;
      gap: var(--space-8);
      font-size: var(--text-sm);
      font-weight: var(--weight-medium);
      color: var(--color-neutral-700);
      background-color: var(--color-white);
      border: 1px solid var(--color-neutral-200);
      border-radius: var(--radius-full);
      padding: var(--space-8) var(--space-16) var(--space-8) var(--space-8);
    }

    .about-hero__eyebrow {
      font-size: var(--text-sm);
      font-weight: var(--weight-semibold);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-neutral-500);
      margin-bottom: var(--space-16);
    }

    .about-hero__title {
      font-size: var(--text-5xl);
      font-weight: var(--weight-regular);
      line-height: var(--leading-tight);
      color: var(--color-neutral-900);
      margin-bottom: var(--space-24);
    }

    .about-hero__subtitle {
      font-size: var(--text-xl);
      font-weight: var(--weight-regular);
      line-height: var(--leading-relaxed);
      color: var(--color-neutral-600);
      max-width: 640px;
      margin: 0 auto;
    }

    /* =============================================
       ABOUT — STORY
       ============================================= */
    .about-story {
      display: flex;
      align-items: center;
      gap: var(--space-48);
      max-width: 1200px;
      margin: 0 auto;
      padding: var(--space-64) var(--space-48);
    }

    .about-story__content {
      flex: 1;
    }

    .about-story__image-wrap {
      flex: 0 0 420px;
      border-radius: var(--radius-xl);
      overflow: hidden;
      border: 1px solid var(--color-neutral-200);
      box-shadow: var(--shadow-md);
    }

    .about-story__image {
      width: 100%;
      height: auto;
      display: block;
    }

    .about-story__title {
      font-size: var(--text-3xl);
      font-weight: var(--weight-semibold);
      line-height: var(--leading-tight);
      color: var(--color-neutral-900);
      margin-bottom: var(--space-24);
    }

    .about-story__text {
      font-size: var(--text-lg);
      font-weight: var(--weight-regular);
      line-height: var(--leading-relaxed);
      color: var(--color-neutral-700);
      margin-bottom: var(--space-16);
    }

    .about-story__text:last-child {
      margin-bottom: 0;
    }

    .about-story__text a {
      color: var(--color-neutral-900);
      font-weight: var(--weight-semibold);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .about-story__text a:hover {
      color: var(--color-neutral-700);
    }

    /* =============================================
       ABOUT — VALUES
       ============================================= */
    .about-values {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-32);
      padding: var(--space-48) var(--space-48) var(--space-64);
    }

    .about-value {
      padding: var(--space-32);
      background-color: rgba(255, 255, 255, 0.85);
      border: 1px solid rgba(255, 255, 255, 0.9);
      border-radius: var(--radius-xl);
    }

    .about-value__icon {
      margin-bottom: var(--space-16);
    }

    .about-value__title {
      font-size: var(--text-xl);
      font-weight: var(--weight-semibold);
      line-height: var(--leading-tight);
      color: var(--color-neutral-900);
      margin-bottom: var(--space-8);
    }

    .about-value__text {
      font-size: var(--text-base);
      font-weight: var(--weight-regular);
      line-height: var(--leading-relaxed);
      color: var(--color-neutral-700);
    }

    /* =============================================
       ABOUT — STATS
       ============================================= */
    .about-stats__subtitle {
      font-size: var(--text-lg);
      font-weight: var(--weight-regular);
      line-height: var(--leading-relaxed);
      color: var(--color-neutral-600);
      text-align: center;
      max-width: 640px;
      margin: 0 auto var(--space-48);
    }

    .about-stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-24);
      list-style: none;
      padding: 0 var(--space-48) var(--space-64);
      margin: 0;
    }

    .about-stat {
      border: 1px solid var(--color-neutral-200);
      border-radius: var(--radius-xl);
      background-color: var(--color-white);
      overflow: hidden;
    }

    .about-stat__image {
      height: 90px;
      background-image: url('/images/stats-panorama.jpg');
      background-size: 400% 100%;
      background-repeat: no-repeat;
      position: relative;
    }

    .about-stat__image::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(255,255,255,0) 60%, rgba(255,255,255,1) 100%);
    }

    .about-stat__image--q1 { background-position: 0% center; }
    .about-stat__image--q2 { background-position: 33.33% center; }
    .about-stat__image--q3 { background-position: 66.66% center; }
    .about-stat__image--q4 { background-position: 100% center; }

    .about-stat__content {
      text-align: center;
      padding: var(--space-24) var(--space-16) var(--space-32);
    }

    .about-stat__number {
      display: block;
      font-size: var(--text-4xl);
      font-weight: var(--weight-semibold);
