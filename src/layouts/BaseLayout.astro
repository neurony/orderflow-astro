---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  article?: {
    publishedTime: string;
    modifiedTime?: string;
    author?: string;
    section?: string;
  };
  noindex?: boolean;
  jsonLd?: Record<string, any> | Record<string, any>[];
}

const props = Astro.props;

// Organization JSON-LD (on every page)
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Corporation',
  '@id': 'https://orderflow.biz/#organization',
  name: 'Orderflow',
  legalName: 'Orderflow by Neurony',
  url: 'https://orderflow.biz',
  logo: {
    '@type': 'ImageObject',
    url: 'https://orderflow.biz/images/logomark.svg',
  },
  description: 'AI-powered order processing automation for distribution businesses. Converts emails, WhatsApp messages, PDFs, scans, and handwritten notes into structured ERP-ready data.',
  foundingDate: '2024',
  areaServed: [
    { '@type': 'Country', name: 'Romania' },
    { '@type': 'Country', name: 'Germany' },
    { '@type': 'Country', name: 'Austria' },
    { '@type': 'Country', name: 'Switzerland' },
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    availableLanguage: ['English', 'Romanian', 'German'],
  },
  sameAs: [
    'https://neurony.ro',
  ],
};

// WebPage schema
const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: props.title,
  description: props.description,
  url: props.canonical || Astro.url.href,
  isPartOf: {
    '@type': 'WebSite',
    name: 'Orderflow',
    url: 'https://orderflow.biz',
  },
  publisher: { '@id': 'https://orderflow.biz/#organization' },
};

const allJsonLd = [
  organizationSchema,
  webPageSchema,
  ...(Array.isArray(props.jsonLd) ? props.jsonLd : props.jsonLd ? [props.jsonLd] : []),
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-PQPSNDHS');</script>
  <!-- End Google Tag Manager -->

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0f172b" />

  <!-- Google Analytics (GA4) — Consent Mode v2, cookieless by default. gtag.js deferred until idle/interaction to eliminate unused-JS Lighthouse warning (~62 KiB). -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    // Grant analytics storage by default to enable Google Ads attribution (gclid → google/cpc in GA4).
    // Ad storage remains denied until explicit user consent (GDPR — no PII stored without consent).
    gtag('consent', 'default', {
      'analytics_storage': 'granted',
      'ad_storage': 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied',
      'url_passthrough': true
    });

    // Defer gtag.js until first user interaction or idle (max 3 s)
    (function() {
      var GA_ID = 'G-Q9RW388339';
      var loaded = false;
      function loadGA() {
        if (loaded) return;
        loaded = true;
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
        s.async = true;
        s.onload = function() {
          gtag('js', new Date());
          gtag('config', GA_ID, {
            'url_passthrough': true,
            'linker': {
              'domains': ['calendly.com'],
              'accept_incoming': true
            }
          });
          gtag('config', 'AW-16637671261', {
            'url_passthrough': true,
            'allow_enhanced_conversions': true
          });
        };
        document.head.appendChild(s);
      }
      var events = ['scroll', 'keydown', 'click', 'mousemove', 'touchstart'];
      function onInteraction() {
        events.forEach(function(e) { document.removeEventListener(e, onInteraction, {passive: true, once: true}); });
        loadGA();
      }
      events.forEach(function(e) { document.addEventListener(e, onInteraction, {passive: true, once: true}); });
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadGA, {timeout: 3000});
      } else {
        setTimeout(loadGA, 3000);
      }
    })();
  </script>

  <!-- Critical CSS — inlined to prevent FOUC while async stylesheets load (NEU-95).
       Contains only above-the-fold structural styles: tokens, reset, body, header layout. -->
  <style is:inline>
    :root{--color-neutral-900:#0f172b;--color-neutral-700:#314158;--color-neutral-600:#4a5568;--color-neutral-500:#62748e;--color-neutral-400:#94a3b8;--color-neutral-300:#cad5e2;--color-neutral-200:#e2e8f0;--color-neutral-100:#f1f5f9;--color-neutral-50:#f8fafc;--color-orange-300:#ffb86a;--color-orange-200:#ffd6a7;--color-purple-600:#4f39f6;--color-purple-200:#DDD6FF;--color-purple-100:rgba(97,95,255,0.1);--color-blue-400:#51a2ff;--color-blue-100:#dbeafe;--color-green-700:#008236;--color-white:#ffffff;--color-white-90:rgba(255,255,255,0.9);--color-white-40:rgba(255,255,255,0.4);--color-black-20:rgba(0,0,0,0.2);--color-black-10:rgba(0,0,0,0.1);--color-black-5:rgba(0,0,0,0.05);--font-sans:'Stack Sans Headline',sans-serif;--font-handwritten:'Caveat',cursive;--text-xs:12px;--text-sm:14px;--text-base:16px;--text-lg:18px;--text-xl:20px;--text-2xl:24px;--text-3xl:32px;--text-4xl:44px;--text-5xl:56px;--leading-tight:1.1;--leading-snug:1.2;--leading-normal:1.5;--leading-relaxed:1.6;--weight-regular:400;--weight-medium:500;--weight-semibold:600;--space-4:4px;--space-8:8px;--space-12:12px;--space-16:16px;--space-24:24px;--space-32:32px;--space-48:48px;--space-64:64px;--space-72:72px;--space-96:96px;--radius-sm:6px;--radius-md:8px;--radius-lg:12px;--radius-xl:16px;--radius-full:9999px;--shadow-sm:0px 8px 40px 0px var(--color-black-5);--shadow-md:0px 8px 24px 0px var(--color-black-10);--shadow-btn:8px 8px 0px 0px var(--color-black-10);--max-width:1512px;--content-width:1368px}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:var(--font-sans);font-size:var(--text-base);font-weight:var(--weight-regular);line-height:var(--leading-normal);color:var(--color-neutral-900);background-color:var(--color-white);-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}
    img{display:block;max-width:100%}
    #app{display:flex;flex-direction:column;min-height:100vh;background-color:var(--color-white);overflow:clip}
    .site-header{position:absolute;top:0;left:0;right:0;z-index:50;background-color:var(--color-white);overflow:hidden}
    :root{--header-height:88px}
    main{padding-top:var(--header-height)}
  </style>

  <!-- Preconnect to critical origins -->
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />

  <!-- DNS prefetch fallback for browsers without preconnect support -->
  <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
  <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
  <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

  <!-- Fonts -->
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Stack+Sans+Headline:wght@400;500;600&family=Caveat:wght@400&display=optional" />
  <link href="https://fonts.googleapis.com/css2?family=Stack+Sans+Headline:wght@400;500;600&family=Caveat:wght@400&display=optional" rel="stylesheet" media="print" onload="this.media='all'" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />

  <!-- SEO -->
  <SEO {...props} jsonLd={allJsonLd} />

  <!-- Speculation Rules for instant navigation -->
  <script type="speculationrules">
  {
    "prefetch": [{ "where": { "href_matches": "/*" }, "eagerness": "moderate" }]
  }
  </script>
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PQPSNDHS"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  <div id="app">
    <Header />
    <slot />
    <Footer />
    <ScrollReveal />
  </div>
</body>
</html>
